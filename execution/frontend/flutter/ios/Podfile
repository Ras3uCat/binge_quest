# Uncomment this line to define a global platform for your project
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig and running flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # Strengthened patch for FLTFirebaseCorePlugin to skip configureWithName:options:
  # when the app is already configured. This prevents EXC_CRASH (FIRApp.m:307).
  bq_found = false
  Dir.glob("#{installer.sandbox.root}/**/FLTFirebaseCorePlugin.{m,mm}") do |file|
    bq_found = true
    puts "[BQ] Found FLTFirebaseCorePlugin at: #{file}"
    content = File.read(file)
    if content.include?('FIRAppAlreadyConfiguredGuard')
      puts "[BQ] Already patched — skipping."
      next
    end
    # More flexible regex that handles different app name and options variables
    patched = content.gsub(
      /(\[FIRApp\s+configureWithName:(.*?)\s+options:(.*?)\];)/,
      "// FIRAppAlreadyConfiguredGuard\n    if ([FIRApp appNamed:\\2] == nil) { \\1 }"
    )
    if patched != content
      File.write(file, patched)
      puts "[BQ] Patched FLTFirebaseCorePlugin successfully."
    else
      puts "[BQ] REGEX DID NOT MATCH. Dumping FIRApp/configure lines:"
      content.each_line { |l| puts "  >> #{l.rstrip}" if l.include?('FIRApp') || l.include?('configure') }
    end
  end
  puts "[BQ] FLTFirebaseCorePlugin found: #{bq_found}"
end

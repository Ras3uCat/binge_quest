# Uncomment this line to define a global platform for your project
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig and running flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # Inject FirebaseInitGuard.m into the Runner Xcode target.
  # This file swizzles +[FIRApp configureWithName:options:] to be idempotent,
  # preventing EXC_CRASH (FIRApp.m:307) from duplicate Firebase initialization.
  require 'xcodeproj'
  guard_name = 'FirebaseInitGuard.m'
  guard_path = File.join(File.dirname(__FILE__), 'Runner', guard_name)
  proj_path  = File.join(File.dirname(__FILE__), 'Runner.xcodeproj')

  if File.exist?(guard_path) && File.exist?(proj_path)
    project      = Xcodeproj::Project.open(proj_path)
    runner_target = project.targets.find { |t| t.name == 'Runner' }
    runner_group  = project.main_group.find_subpath('Runner', false)

    if runner_target && runner_group
      already_added = runner_target.source_build_phase.files.any? do |f|
        f.file_ref&.path == guard_name
      end
      unless already_added
        file_ref = runner_group.new_file(guard_name)
        runner_target.source_build_phase.add_file_reference(file_ref)
        project.save
        puts "[BQ] Injected #{guard_name} into Runner compile sources."
      else
        puts "[BQ] #{guard_name} already in Runner compile sources."
      end
    else
      puts "[BQ] ERROR: Could not find Runner target or group in Xcode project."
    end
  else
    puts "[BQ] SKIP: #{guard_name} not found at ios/Runner/#{guard_name}"
  end
end
